name: OPA Workloads — Read Secret

# Demonstrates secretless authentication to Okta Privileged Access (OPA) using
# a GitHub OIDC token, then reveals one configured secret.
#
# Required GitHub Actions Variables (Settings → Secrets and variables → Variables):
#   OPA_ADDR                 — OPA tenant URL (e.g. https://xyz.pam.okta.com)
#   SFT_TEAM                 — OPA team name (e.g. xyz)
#   OPA_WORKLOAD_CONNECTION  — optional, defaults to github-actions
#   OPA_WORKLOAD_ROLE        — optional, defaults to workload-role-1
#   SECRET_RESOURCE_GROUP    — optional, defaults to production_servers
#   SECRET_PROJECT           — optional, defaults to secrets
#   SECRET_FOLDER            — optional, defaults to production_server_secrets
#   SECRET_NAME              — optional, defaults to MySql_root

on:
  workflow_dispatch:
  push:
    branches:
      - main

permissions:
  id-token: write   # Required to request a GitHub OIDC token
  contents: read

jobs:
  read-secret:
    name: Read one secret from OPA via Workloads
    runs-on: ubuntu-24.04

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install sft CLI
        run: |
          set -euo pipefail

          if command -v sft >/dev/null 2>&1; then
            echo "✅ sft already installed: $(sft --version)"
            exit 0
          fi

          # Add the Okta Privileged Access repository key.
          curl -fsSL https://dist.scaleft.com/GPG-KEY-OktaPAM-2023 | gpg --dearmor | sudo tee /usr/share/keyrings/oktapam-2023-archive-keyring.gpg > /dev/null

          # Create a package resource list entry for Ubuntu 24.04 noble.
          echo "deb [signed-by=/usr/share/keyrings/oktapam-2023-archive-keyring.gpg] https://dist.scaleft.com/repos/deb noble okta" | sudo tee /etc/apt/sources.list.d/oktapam-stable.list > /dev/null

          # Install the sft CLI.
          echo "📦 Installing sft CLI (quiet mode)..."
          sudo apt-get -qq update
          sudo DEBIAN_FRONTEND=noninteractive apt-get -qq install -y \
            -o Dpkg::Use-Pty=0 \
            -o Dpkg::Progress-Fancy=0 \
            scaleft-client-tools

          echo "✅ sft installed: $(sft --version)"

      - name: Request GitHub OIDC token
        env:
          OPA_ADDR: ${{ vars.OPA_ADDR }}
        run: |
          set -euo pipefail

          if [ -z "$OPA_ADDR" ]; then
            echo "❌ Invalid configuration: OPA_ADDR is required."
            exit 1
          fi

          OIDC_TOKEN=$(curl -sSfL \
            -H "Authorization: bearer ${ACTIONS_ID_TOKEN_REQUEST_TOKEN}" \
            "${ACTIONS_ID_TOKEN_REQUEST_URL}&audience=${OPA_ADDR}" \
            | jq -r '.value')

          if [ -z "$OIDC_TOKEN" ] || [ "$OIDC_TOKEN" = "null" ]; then
            echo "❌ Failed to obtain GitHub OIDC token"
            exit 1
          fi

          # ⚠️ LAB DEBUG ONLY:
          # GitHub masks the full OIDC token in logs, and printing raw tokens is unsafe.
          # For troubleshooting, print only the decoded JWT header and payload claims.
          # This lab prints claims by design. Do not copy this behavior to production workflows.
          echo "⚠️ LAB DEBUG: OIDC token claims are printed below. Do not do this in production."

          decode_jwt_part() {
            local part="$1"
            local padded_part
            padded_part=$(printf '%s' "$part" | tr '_-' '/+')

            case $((${#padded_part} % 4)) in
              2) padded_part="${padded_part}==" ;;
              3) padded_part="${padded_part}=" ;;
            esac

            printf '%s' "$padded_part" | base64 -d 2>/dev/null | jq .
          }

          JWT_HEADER=$(decode_jwt_part "$(echo "$OIDC_TOKEN" | cut -d '.' -f 1)")
          JWT_PAYLOAD=$(decode_jwt_part "$(echo "$OIDC_TOKEN" | cut -d '.' -f 2)")

          echo "OIDC_TOKEN_HEADER:"
          echo "$JWT_HEADER"
          echo "OIDC_TOKEN_PAYLOAD:"
          echo "$JWT_PAYLOAD"

          echo "::add-mask::$OIDC_TOKEN"
          echo "OIDC_TOKEN=$OIDC_TOKEN" >> "$GITHUB_ENV"
          echo "✅ GitHub OIDC token obtained"

      - name: Authenticate with OPA Workloads
        env:
          OPA_ADDR: ${{ vars.OPA_ADDR }}
          SFT_TEAM: ${{ vars.SFT_TEAM }}
          OPA_WORKLOAD_CONNECTION: ${{ vars.OPA_WORKLOAD_CONNECTION || 'github-actions' }}
          OPA_WORKLOAD_ROLE: ${{ vars.OPA_WORKLOAD_ROLE || 'workload-role-1' }}
        run: |
          set -euo pipefail

          if [ -z "$SFT_TEAM" ]; then
            echo "❌ Invalid configuration: SFT_TEAM is required."
            exit 1
          fi

          export OPA_TOKEN=$(sft wl authenticate \
            --team "$SFT_TEAM" \
            --connection "$OPA_WORKLOAD_CONNECTION" \
            --jwt-env OIDC_TOKEN \
            --role-hint "$OPA_WORKLOAD_ROLE" \
            2>&1 | tr -d '\n\r')

          if [[ "$OPA_TOKEN" == *"error"* ]] || [ -z "$OPA_TOKEN" ]; then
            echo "❌ Failed to obtain OPA bearer token"
            echo "Detail: $OPA_TOKEN"
            exit 1
          fi

          # ⚠️ LAB DEBUG ONLY:
          # Print decoded OPA token content when the token is JWT-shaped.
          # This is useful for troubleshooting capabilities and claims, but do not do this in production.
          echo "⚠️ LAB DEBUG: OPA token content is printed below when decodable. Do not do this in production."

          decode_jwt_part() {
            local part="$1"
            local padded_part
            padded_part=$(printf '%s' "$part" | tr '_-' '/+')

            case $((${#padded_part} % 4)) in
              2) padded_part="${padded_part}==" ;;
              3) padded_part="${padded_part}=" ;;
            esac

            printf '%s' "$padded_part" | base64 -d 2>/dev/null | jq .
          }

          if [[ "$OPA_TOKEN" == *.*.* ]]; then
            OPA_TOKEN_HEADER=$(decode_jwt_part "$(echo "$OPA_TOKEN" | cut -d '.' -f 1)" || true)
            OPA_TOKEN_PAYLOAD=$(decode_jwt_part "$(echo "$OPA_TOKEN" | cut -d '.' -f 2)" || true)

            if [ -n "$OPA_TOKEN_HEADER" ] && [ -n "$OPA_TOKEN_PAYLOAD" ]; then
              echo "OPA_TOKEN_HEADER:"
              echo "$OPA_TOKEN_HEADER"
              echo "OPA_TOKEN_PAYLOAD:"
              echo "$OPA_TOKEN_PAYLOAD"
            else
              echo "OPA_TOKEN could not be decoded as JSON JWT content."
            fi
          else
            echo "OPA_TOKEN is not JWT-shaped; it appears to be opaque, so there are no local claims to print."
          fi

          echo "::add-mask::$OPA_TOKEN"
          echo "OPA_TOKEN=$OPA_TOKEN" >> "$GITHUB_ENV"
          echo "OPA_ADDR=$OPA_ADDR"   >> "$GITHUB_ENV"
          echo "SFT_TEAM=$SFT_TEAM"   >> "$GITHUB_ENV"
          echo "✅ OPA bearer token obtained via workload authentication"

      - name: Reveal OPA secret
        env:
          SECRET_RESOURCE_GROUP: ${{ vars.SECRET_RESOURCE_GROUP || 'production_servers' }}
          SECRET_PROJECT: ${{ vars.SECRET_PROJECT || 'secrets' }}
          SECRET_FOLDER: ${{ vars.SECRET_FOLDER || 'production_server_secrets' }}
          SECRET_NAME: ${{ vars.SECRET_NAME || 'MySql_root' }}
        run: |
          set -euo pipefail
          echo "🔑 OPA secrets reveal"
          echo " "
          echo "📋 List available secrets:"
          echo " "

          sft secrets list

          echo " "
          echo "⚙️ Running: sft secrets reveal command"
          echo "📦 Resource group: ${SECRET_RESOURCE_GROUP}"
          echo "   🗂️ Project: ${SECRET_PROJECT}"
          echo "      📁 Folder: ${SECRET_FOLDER}"
          echo "         🔑 Secret: ${SECRET_NAME}"
          echo " "

          KV_PAIRS=$(sft secrets reveal \
            --team           "$SFT_TEAM" \
            --resource-group "$SECRET_RESOURCE_GROUP" \
            --project        "$SECRET_PROJECT" \
            --path           "$SECRET_FOLDER" \
            --name           "$SECRET_NAME" \
            --output json)

          while read -r kv; do
            KEY=$(echo "$kv"   | jq -r '.key_name')
            VALUE=$(echo "$kv" | jq -r '.secret_value')
            echo "::add-mask::$VALUE"
            echo "      ${KEY}: ***"
          done < <(echo "$KV_PAIRS" | jq -c '.[]')

          echo " "
          echo "✅ OPA secret reveal completed successfully"
