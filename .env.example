# GitHub Actions Variables — OPA Workloads Lab
#
# Usage:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below
#   3. Import into GitHub:  gh variable set --env-file .env
#
# These are GitHub Actions *Variables* (not secrets) — no sensitive values here.

# Shared OPA Workloads settings

# OPA tenant URL
OPA_ADDR=https://xyz.pam.okta.com

# OPA team name (Security Administration → Teams)
SFT_TEAM=xyz

# Name of the Workload Connection configured in OPA
# (DevOps Administration → Workload connections)
OPA_WORKLOAD_CONNECTION=github-actions

# Name of the Workload Role configured in OPA
# (Security Administration → Workload roles)
OPA_WORKLOAD_ROLE=workload-role-1

# SSH workflow settings

# Optional override: defaults to opa-linux-target
OPA_LINUX_TARGET=opa-linux-target

# Optional AWS Security Group auto-update for the SSH workflow.
# Disabled by default. Configure AWS_GROUP_ID and AWS_ROLE_TO_ASSUME to enable it.
#
# AWS_GROUP_ID=sg-0123456789abcdef0
# AWS_ROLE_TO_ASSUME=arn:aws:iam::123456789012:role/github-opa-lab-sg-updater
#
# Optional override: defaults to us-east-1
# AWS_REGION=us-east-1
#
# Optional override: defaults to 7234
# AWS_SECURITY_GROUP_PORT=7234

# Unused
# SSH_PROJECT=web_servers
